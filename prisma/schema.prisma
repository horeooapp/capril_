// ═══════════════════════════════════════════════════════
// MODULE M17 — FISCAL REGISTRATION
// ═══════════════════════════════════════════════════════
model FiscalDossier {
  id      String @id @default(uuid()) @map("fiscal_id")
  leaseId String @map("bail_id")
  lease   Lease  @relation(fields: [leaseId], references: [id])

  loyerMensuel         Int     @map("loyer_mensuel")
  dureeBailMois        Int     @map("duree_bail_mois")
  dureeRetenueMois     Int     @map("duree_retenue_mois")
  baseCalcul           Int     @map("base_calcul")
  tauxApplique         Float @default(0.0250) @map("taux_applique")
  droitsEnregistrement Int     @map("droits_enregistrement")
  fraisTimbre          Int     @default(1000) @map("frais_timbre")
  fraisQapril          Int     @map("frais_qapril")
  totalDgi             Int     @map("total_dgi")
  totalBailleur        Int     @map("total_bailleur")
  penaltyAmount        Int     @default(0) @map("penalty_amount")
  exonere              Boolean @default(false)

  statut           String @default("EN_ATTENTE_DECLARATION")
  dateLimiteLegale DateTime     @map("date_limite_legale")

  cinetpayTransId    String?   @map("cinetpay_transaction_id")
  cinetpayPaymentUrl String?   @map("cinetpay_payment_url")
  paidAt             DateTime? @map("paid_at")

  certificat CertificatFiscal?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leaseId])
  @@index([statut])
  @@map("fiscal_dossiers")
}

model CertificatFiscal {
  id            String        @id @default(uuid()) @map("certificat_id")
  fiscalId      String        @unique @map("fiscal_id")
  fiscalDossier FiscalDossier @relation(fields: [fiscalId], references: [id])

  numeroCertificat String @unique @map("numero_certificat")
  qrToken          String @unique @map("qr_token")
  pdfPath          String @map("pdf_path")
  hashSha256       String @map("hash_sha256")

  issuedAt DateTime @default(now()) @map("issued_at")
  status   String   @default("VALIDE")

  @@map("certificats_fiscaux")
}

model PrepaymentRequest {
  id         String @id @default(uuid())
  leaseId    String @map("lease_id")
  lease      Lease  @relation(fields: [leaseId], references: [id])
  tenantId   String @map("tenant_id")
  tenant     User   @relation("TenantPrepayments", fields: [tenantId], references: [id])
  landlordId String @map("landlord_id")
  landlord   User   @relation("LandlordValidations", fields: [landlordId], references: [id])

  monthsCount Int                     @map("months_count")
  totalAmount Int                     @map("total_amount")
  reason      String?
  status      String @default("PENDING")

  rejectionReason String?   @map("rejection_reason")
  approvedAt      DateTime? @map("approved_at")
  rejectedAt      DateTime? @map("rejected_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leaseId])
  @@index([tenantId])
  @@index([landlordId])
  @@index([status])
  @@map("prepayment_requests")
}

// ═══════════════════════════════════════════════════════
// MODULE M-PGW — PAYMENT GATEWAY (ABSTRACTION)
// ═══════════════════════════════════════════════════════

model PaymentPgw {
  id           String   @id @default(uuid()) @map("payment_id")
  leaseId      String   @map("lease_id")
  lease        Lease    @relation(fields: [leaseId], references: [id])
  moisConcerne DateTime @map("mois_concerne")
  montant      Float

  payeurId       String @map("payeur_id")
  payeur         User   @relation("PayerTransactions", fields: [payeurId], references: [id])
  beneficiaireId String @map("beneficiaire_id")
  beneficiaire   User   @relation("BeneficiaryTransactions", fields: [beneficiaireId], references: [id])

  canal PaymentCanal
  msisdnPayeur       String?      @map("msisdn_payeur")
  msisdnBeneficiaire String?      @map("msisdn_beneficiaire")

  statut PaymentPgwStatus @default(INITIEE)

  refInterne   String  @unique @map("ref_interne")
  refOperateur String? @map("ref_operateur")
  refCinetpay  String? @map("ref_cinetpay")

  webhookPayload    Json?     @map("webhook_payload")
  webhookReceivedAt DateTime? @map("webhook_received_at")

  quittanceId String?  @map("quittance_id")
  quittance   Receipt? @relation(fields: [quittanceId], references: [id])

  webhooks        PgwWebhook[]
  tvaTransactions TvaTransaction[]

  sourceMigrationId String?           @map("source_migration_id")
  sourceMigration   MigrationSession? @relation(fields: [sourceMigrationId], references: [id])

  tentatives Int       @default(0)
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // M-PAY-AUTO
  reversalStatus   String        @default("PENDING") @map("reversal_status")
  honorairesAgence Float?              @map("honoraires_agence")
  reversals        ReversalTransaction[]

  @@index([leaseId, moisConcerne])
  @@index([statut, expiresAt])
  @@index([refInterne])
  @@map("payments_pgw")
}



model ReversalTransaction {
  id           String       @id @default(uuid()) @map("reversal_id")
  paymentId    String       @map("payment_id")
  payment      PaymentPgw   @relation(fields: [paymentId], references: [id])
  recipientId  String       @map("recipient_id")
  recipient    User         @relation(fields: [recipientId], references: [id])
  type         String
  amount       Float
  status       String       @default("SUCCESS") // SUCCESS, FAILED
  referencePgw String?      @map("reference_pgw")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("reversal_transactions")
}







model PgwWebhook {
  id              String       @id @default(uuid()) @map("webhook_id")
  canal PaymentCanal
  refOperateur    String?      @map("ref_operateur")
  payload         Json
  signatureValide Boolean      @map("signature_valid")
  traite          Boolean      @default(false)
  paymentId       String?      @map("payment_id")
  payment         PaymentPgw?  @relation(fields: [paymentId], references: [id])
  receivedAt      DateTime     @default(now()) @map("received_at")

  @@index([refOperateur, canal])
  @@map("pgw_webhooks")
}

model PgwMsisdnLookup {
  prefixe   String       @id @map("prefixe")
  operateur PaymentCanal
  actif     Boolean      @default(true)
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("pgw_msisdn_lookup")
}

model PgwReconciliation {
  id                      String       @id @default(uuid()) @map("recon_id")
  dateRecon               DateTime     @map("date_recon")
  canal PaymentCanal
  nbTransactionsQapril    Int          @map("nb_transactions_qapril")
  nbTransactionsOperateur Int?         @map("nb_transactions_operateur")
  montantTotalQapril      Float      @map("montant_total_qapril")
  montantTotalOperateur   Float?     @map("montant_total_operateur")
  nbEcarts                Int          @default(0) @map("nb_ecarts")
  ecartsDetail            Json?        @map("ecarts_detail")
  statut                  String       @default("EN_COURS")
  createdAt               DateTime     @default(now()) @map("created_at")

  @@map("pgw_reconciliation")
}

model FeatureFlag {
  id          String   @id @map("flag_id")
  name        String   @unique
  description String?
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

