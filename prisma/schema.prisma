// M-EDL — États des Lieux
model EtatsDesLieux {
  id               String      @id @default(uuid()) @map("edl_id")
  leaseId          String      @map("lease_id")
  lease            Lease       @relation(fields: [leaseId], references: [id])
  typeEdl          String     @map("type_edl") // ENTREE | SORTIE
  statut EdlStatut @default(EN_COURS)
  
  redigeParId      String      @map("redige_par")
  redigePar        User        @relation("RedacteurEdl", fields: [redigeParId], references: [id])
  
  agentId          String?     @map("agent_id")
  agent            User?       @relation("AgentEdls", fields: [agentId], references: [id])
  locataireId      String?     @map("locataire_id")
  locataire        User?       @relation("LocataireEdls", fields: [locataireId], references: [id])
  
  dateEdl          DateTime    @default(now()) @map("date_edl")
  sections         Json? // Sections/photos/etats
  
  indexEau         Float?    @map("index_eau")
  indexElec        Float?    @map("index_elec")
  
  clesRemises      Int         @default(0) @map("cles_remises")
  clesDetail       String?     @map("cles_detail")
  
  reservesLocataire String?    @map("reserves_locataire")
  
  confirmeProprio    Boolean   @default(false) @map("confirme_proprio")
  confirmeLocataire  Boolean   @default(false) @map("confirme_locataire")
  confirmeProprioAt  DateTime? @map("confirme_proprio_at")
  confirmeLocataireAt DateTime? @map("confirme_locataire_at")
  expireConfirmationAt DateTime? @map("expire_confirmation_at")
  
  refEdl           String?     @unique @map("ref_edl")
  hashSha256       String?     @map("hash_sha256")
  pdfUrl           String?     @map("pdf_url")
  
  edlEntreeId      String?     @map("edl_entree_id")
  edlEntree        EtatsDesLieux? @relation("EdlEntreeSortie", fields: [edlEntreeId], references: [id])
  edlSorties       EtatsDesLieux[] @relation("EdlEntreeSortie")
  
  createdAt        DateTime    @default(now()) @map("created_at")

  @@map("etats_des_lieux")
}



