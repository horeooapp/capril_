// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Rôles ---
enum UserType {
  PERSON
  COMPANY
}

enum Role {
  ADMIN
  LANDLORD
  AGENCY
  TENANT
  AUDITOR
  NON_CERTIFIED_AGENT
}

// --- Modèles NextAuth ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?   @unique
  userType      UserType  @default(PERSON)
  companyName   String?
  nationality   String?
  profession    String?
  cniNumber     String?   // Ou tout autre document d'identité
  birthDate     DateTime?
  password      String?
  role          Role      @default(TENANT)
  
  // Indice de Confiance Locatif (ICL)
  reliabilityScore Int    @default(750) // Entre 300 et 1000
  trustEvents      TrustEvent[]

  // Champs pour les agents
  isCertified       Boolean?  @default(false)
  certificationDate DateTime?

  accounts Account[]
  sessions Session[]

  // Relations métier
  propertiesOwned   Property[] @relation("PropertyOwner")
  propertiesManaged Property[] @relation("PropertyManager")
  leasesAsTenant    Lease[]    @relation("LeaseTenant")
  mandates          Mandate[]  @relation("AgentMandates")
  auditLogs         AuditLog[]
  notifications    Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  link      String?  // Optionnel: lien vers l'entité concernée (ex: /dashboard/leases/id)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Modèles Métier QAPRIL ---

enum EscrowStatus {
  ACTIVE
  EN_LITIGE
  LIBERE
  PARTIELLEMENT_LIBERE
}

model Escrow {
  id        String       @id @default(cuid())
  leaseId   String       @unique
  lease     Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  amount    Float
  status    EscrowStatus @default(ACTIVE)
  
  // Historique des mouvements pour la preuve renforcée
  history   String?      // JSON stringified history of status changes
  
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Property {
  id           String  @id @default(cuid())
  name         String? // Ex: "Appartement A1"
  address      String
  city         String
  neighborhood String?
  postalCode   String?
  lotNumber     String? // Numéro du lot
  dependencies  String? // Détail des dépendances
  usage         String  @default("Habitation")
  
  // Passeport Logement
  surface              Float?
  digitalPostalAddress String?
  gpsLatitude          Float?
  gpsLongitude         Float?
  
  country       String  @default("Côte d'Ivoire")
  type         String  @default("APARTMENT")

  ownerId String
  owner   User   @relation("PropertyOwner", fields: [ownerId], references: [id])

  managerId String? // En cas de gestion déléguée à une agence
  manager   User?   @relation("PropertyManager", fields: [managerId], references: [id])

  leases   Lease[]
  mandates Mandate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MandateType {
  EXCLUSIVE
  NON_EXCLUSIVE
}

enum MandateStatus {
  PENDING
  VALIDATED
  REJECTED
  EXPIRED
}

model Mandate {
  id         String @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  agentId String
  agent   User   @relation("AgentMandates", fields: [agentId], references: [id])

  type        MandateType   @default(NON_EXCLUSIVE)
  status      MandateStatus @default(PENDING)
  startDate   DateTime
  endDate     DateTime?
  documentUrl String? // URL du mandat signé
  
  // Preuve renforcée
  proofHash   String? @unique // Empreinte cryptographique du document/mandat

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String // Ex: "CREATE_LEASE", "VALIDATE_MANDATE"
  entityType String // Ex: "LEASE", "MANDATE"
  entityId   String
  details    String? // JSON stringifié pour plus de détails
  
  // Horodatage avancé pour la preuve renforcée
  timestamp  DateTime @default(now())
  proofHash  String?  // Hash combiné (prevLogHash + currentLogData)
}

enum LeaseStatus {
  // Existing statuses
  PENDING
  ACTIVE
  TERMINATED
  
  // New unpaid rent workflow statuses
  LOYER_IMPAYE
  MISE_EN_DEMEURE
  DELAI_LEGAL
  CLEMENCE_EN_COURS
  REPRISE_PROCEDURE
  DEMANDE_RESILIATION
  EN_CONTENTIEUX
  RESILIE_AMIABLEMENT
  RESILIE_JUDICIAIREMENT
}

model Lease {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   User   @relation("LeaseTenant", fields: [tenantId], references: [id])

  startDate   DateTime
  endDate     DateTime?
  renewalMode String?   @default("Tacite reconduction")
  
  // Nouveaux champs officiels pour le registre numérique
  officialLeaseNumber String? @unique // Numéro unique figurant sur le contrat physique
  scanUrl             String? // URL du document scanné ou PDF du contrat

  rentAmount Float // Loyer mensuel de base
  paymentDueDate Int? @default(5) // Jour d'échéance du paiement (ex: le 5 du mois)
  charges    Float?    @default(0) // Charges locatives
  deposit    Float? // Caution (max 2 mois)
  
  // Nouveaux champs financiers
  advancePayment Float? @default(0) // Avance sur loyer (max 2 mois)
  agencyFee      Float? @default(0) // Frais d'agence (max 1 mois)
  legalPlafonningMet Boolean? @default(true) // Indicateur si le plafond légal est respecté

  // Etat des lieux (textuel ou lien vers un document/JSON)
  entryInventoryNotes String? 
  exitInventoryNotes  String? 

  status LeaseStatus @default(ACTIVE)

  // Signature Numérique
  tenantSignature String?
  ownerSignature  String?
  signedAt       DateTime?

  incidents      Incident[]
  receipts       Receipt[]
  escrow         Escrow?
  insurance      Insurance?
  cdcDeposit     CDCDeposit?
  mediation      Mediation?
  repaymentPlans RepaymentPlan[]
  procedurePhases ProcedurePhase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlanStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  RESPECTED
  BROKEN
}

model RepaymentPlan {
  id              String      @id @default(cuid())
  leaseId         String
  lease           Lease       @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  
  details         String      // Description de l'échéancier (JSON pour les dates/montants)
  status          PlanStatus  @default(PROPOSED)
  
  // Signatures électroniques (Hash + Date)
  ownerSignature  String?
  tenantSignature String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ProcedurePhase {
  id          String   @id @default(cuid())
  leaseId     String
  lease       Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  phaseNumber Int      // Ex: 1 à 10 comme décrit dans l'addendum
  name        String   // Nom de la phase
  description String?  // Détails additionnels
  
  createdAt   DateTime @default(now())
  
  // Association optionnelle avec un document ou preuve
  proofHash   String?
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CREDIT_CARD
  OTHER
}

enum InsuranceStatus {
  INACTIVE
  ACTIVE
  PENDING
  CANCELLED
}

model Insurance {
  id        String          @id @default(cuid())
  leaseId   String          @unique
  lease     Lease           @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  status    InsuranceStatus @default(INACTIVE)
  provider  String?         // Nom de l'assureur
  policyNo  String?         @unique
  
  claims    InsuranceClaim[]
  
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model InsuranceClaim {
  id          String   @id @default(cuid())
  insuranceId String
  insurance   Insurance @relation(fields: [insuranceId], references: [id], onDelete: Cascade)
  amount      Float
  reason      String
  status      String   @default("OPEN") // OPEN, PAID, REJECTED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum CDCDepositStatus {
  PENDING
  CONSIGNED
  RELEASED
  DISPUTED
}

enum CDCDepositInitiator {
  TENANT
  OWNER
}

enum MediationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  FAILED
}

model Mediation {
  id        String          @id @default(cuid())
  leaseId   String          @unique
  lease     Lease           @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  status    MediationStatus @default(OPEN)
  subject   String
  messages  MediationMessage[]
  
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model MediationMessage {
  id          String    @id @default(cuid())
  mediationId String
  mediation   Mediation @relation(fields: [mediationId], references: [id], onDelete: Cascade)
  senderId    String
  content     String
  
  createdAt   DateTime  @default(now())
}

model MarketData {
  id           String   @id @default(cuid())
  city         String
  neighborhood String   @default("")
  propertyType String   // APARTMENT, HOUSE, etc.
  averageRent  Float
  sampleSize   Int
  
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([city, neighborhood, propertyType])
}

model CDCDeposit {
  id           String             @id @default(cuid())
  leaseId      String             @unique
  lease        Lease              @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  initiator    CDCDepositInitiator
  amount       Float
  cdcReference String?            @unique
  status       CDCDepositStatus   @default(PENDING)
  proofHash    String?
  
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Receipt {
  id            String @id @default(cuid())
  receiptNumber String @unique // Numéro unique de quittance pour la légalité et l'audit

  leaseId String
  lease   Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  periodStart DateTime // Début de la période de location
  periodEnd   DateTime // Fin de la période de location

  amountPaid    Float // Montant réellement payé
  paymentDate   DateTime
  paymentMethod PaymentMethod @default(MOBILE_MONEY)

  isSent     Boolean @default(false) // Pour l'optimisation des notifications
  pdfUrl     String? // URL du PDF de quittance archivé
  qrCodeHash String? @unique // Hash pour le QR code
  
  // Preuve renforcée
  documentHash String? @unique // Empreinte cryptographique (SHA256) du contenu

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Module: Indice de Confiance Locatif (ICL) ---

model TrustEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  points    Int      // Ex: +2, -30
  reason    String   // Ex: "Paiement à temps", "Retard > 30j"
  createdAt DateTime @default(now())

  relatedEntityId String? // ID de la quittance ou du bail lié
}

// --- Module: Passeport Logement & Incidents ---

model Incident {
  id          String   @id @default(cuid())
  leaseId     String
  lease       Lease    @relation(fields: [leaseId], references: [id])
  reporterId  String
  type        String   // Ex: DEGRADATION, LITIGE_CAUTION, BRUIT
  description String
  severity    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status      String   @default("OPEN")   // OPEN, RESOLVED
  createdAt   DateTime @default(now())
}
