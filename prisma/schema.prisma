  // WhatsApp
  waActif   Boolean @default(true) @map("wa_actif")
  waNumero  String? @map("wa_numero") @db.VarChar(20)
  waVerifie Boolean @default(false) @map("wa_verifie")

  // Email
  emailActif   Boolean @default(false) @map("email_actif")
  emailAdresse String? @map("email_adresse") @db.VarChar(200)
  emailVerifie Boolean @default(false) @map("email_verifie")

  // SMS & Push
  smsActif  Boolean @default(true) @map("sms_actif")
  pushActif Boolean @default(true) @map("push_actif")
  pushToken String? @map("push_token") @db.Text

  // Plages horaires CI
  heureDebut Int @default(7) @map("heure_debut") @db.SmallInt
  heureFin   Int @default(21) @map("heure_fin") @db.SmallInt

  evenementsActifs Json? @default("{\"QUITTANCE_GENEREE\": [\"wa\",\"sms\",\"email\"], \"PAIEMENT_RECU\": [\"wa\",\"sms\"], \"IMPAYE_DETECTE\": [\"wa\",\"sms\"], \"BAIL_CONFIRME\": [\"wa\",\"sms\",\"email\"], \"RAPPORT_MENSUEL\": [\"wa\",\"email\"], \"WALLET_BAS\": [\"wa\",\"sms\"], \"BAIL_EXPIRANT\": [\"wa\",\"sms\"]}") @map("evenements_actifs")

  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

model NotificationLog {
  id             String      @id @default(uuid()) @map("notif_id")
  userId         String      @map("user_id")
  user           User        @relation(fields: [userId], references: [id])
  canal          NotifCanal
  typeEvenement  String      @map("type_evenement") @db.VarChar(50)
  referenceId    String?     @map("reference_id")
  templateId     String?     @map("template_id") @db.VarChar(60)
  contenuPreview String?     @map("contenu_preview") @db.Text
  statut         NotifStatut @default(EN_ATTENTE)
  nbTentatives   Int         @default(0) @map("nb_tentatives") @db.SmallInt
  erreurDetail   String?     @map("erreur_detail") @db.Text

  envoyeAt  DateTime? @map("envoye_at")
  livreAt   DateTime? @map("livre_at")
  luAt      DateTime? @map("lu_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([statut, createdAt])
  @@map("notification_logs")
}

// ═══════════════════════════════════════════════════════
// ADD-11 : Rôles & Réclamations
// ═══════════════════════════════════════════════════════
enum BienRole {
  OWNER
  MANAGER
  FIELD_AGENT
}

enum DeclStatut {
  EN_ATTENTE
  CONFIRME
  CONTESTE
  EXPIRE
  AUTO_GENERE
}

model PropertyAccess {
  id         String    @id @default(uuid()) @map("acces_id")
  propertyId String    @map("bien_id")
  userId     String    @map("user_id")
  role       BienRole
  statut     String    @default("ACTIF") // ACTIF | SUSPENDU | REVOQUE
  invitedById String?  @map("invite_par")
  invitedAt  DateTime? @default(now()) @map("invite_at")
  acceptedAt DateTime? @map("accepte_at")
  revokedAt  DateTime? @map("revoque_at")
  note       String?   @db.Text

  property   Property @relation("PropertyRoles", fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy  User?    @relation("InvitedRoles", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([propertyId, userId])
  @@map("bien_acces")
}

model SmsDeclaration {
  id              String      @id @default(uuid()) @map("decl_id")
  leaseId         String      @map("bail_id")
  tenantId        String      @map("locataire_id")
  montantDeclare  Decimal     @map("montant_declare") @db.Decimal(12,0)
  canal           String      @default("SMS") // SMS | WHATSAPP | APP
  statut          DeclStatut  @default(EN_ATTENTE)
  confirmeParId   String?     @map("confirme_par")
  confirmeAt      DateTime?   @map("confirme_at")
  receiptId       String?     @map("quittance_id")
  rappel1At       DateTime?   @map("rappel_1_at")
  alerteProprioAt DateTime?   @map("alerte_proprio_at")
  smsBrut         String?     @map("sms_brut") @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  expireAt        DateTime?   @map("expire_at")

  lease       Lease   @relation("LeaseDeclarations", fields: [leaseId], references: [id], onDelete: Cascade)
  tenant      User    @relation("TenantDeclarations", fields: [tenantId], references: [id], onDelete: Cascade)
  confirmePar User?   @relation("ManagerConfirmations", fields: [confirmeParId], references: [id], onDelete: SetNull)

  @@index([statut, createdAt])
  @@map("sms_declarations")
}
