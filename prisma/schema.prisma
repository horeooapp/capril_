// M-MAINT — Maintenance & Travaux (ADD-17)
model TicketMaintenance {
  id                 String              @id @default(uuid()) @map("ticket_id")
  ticketRef          String              @unique @map("ticket_ref") // MAI-0001
  
  logementId         String?             @map("unite_id")
  logement           Property?           @relation(fields: [logementId], references: [id])
  
  leaseId            String              @map("lease_id")
  lease              Lease               @relation(fields: [leaseId], references: [id])
  
  locataireId        String              @map("locataire_id")
  locataire          User                @relation("MaintenanceDeclarant", fields: [locataireId], references: [id])
  
  categorie          String @map("categorie_v2")
  description        String
  
  // V1 Compatibility
  photosUrls String @default("[]") @map("photos_urls")
  urgence            String              @default("NORMALE") // URGENTE|NORMALE|BASSE
  
  // V2 requirements
  photoUrl           String?             @map("photo_url")
  photoHashSha256    String?             @map("photo_hash_sha256")
  statut             String   @default("EN_ATTENTE")
  
  dateSignalement    DateTime            @default(now()) @map("date_signalement")
  datePriseEnCharge  DateTime?           @map("date_prise_en_charge")
  dateResolution     DateTime?           @map("date_resolution")
  nbReouvertures     Int                 @default(0) @map("nb_reouvertures")
  commentaireProprio String?             @map("commentaire_proprio")
  confirmationLoc    Boolean?            @map("confirmation_locataire")
  dateConfirmation   DateTime?           @map("date_confirmation")

  prestataireId      String?             @map("prestataire_id")
  prestataire        Prestataire?        @relation(fields: [prestataireId], references: [id])

  devisMontant       Float?            @map("devis_montant")
  coutFinal          Float?            @map("cout_final")
  dateIntervention   DateTime?           @map("date_intervention")

  noteLocataire      Int?                @map("note_locataire")
  notePrestataire    Int?                @map("note_prestataire")

  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  closedAt           DateTime?           @map("closed_at")

  @@index([leaseId])
  @@index([statut])
  @@map("tickets_maintenance")
}

