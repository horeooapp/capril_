model FactureUtility {
  id                  String        @id @default(uuid()) @map("facture_id")
  leaseId             String        @map("lease_id")
  lease               Lease         @relation(fields: [leaseId], references: [id])
  acteurId            String        @map("acteur_id")
  acteur              User          @relation(fields: [acteurId], references: [id])
  roleActeur          String        @map("role_acteur") // PROPRIO | LOCATAIRE
  typeUtility         String   @map("type_utility")
  identifiantCompteur String        @map("identifiant_compteur")
  moisFacture         DateTime      @map("mois_facture")
  montantTotal        Float       @map("montant_total")
  dateLimitePaiement  DateTime?     @map("date_limite_paiement")
  statut UtilityStatus @default(EN_COURS)
  source              String        @default("SAISIE_MANUELLE") // API_ORANGE | API_MTN | ...
  modeUtilities       String   @map("mode_utilities")
  datePaiement        DateTime?     @map("date_paiement")
  createdAt           DateTime      @default(now()) @map("created_at")

  repartitions        RepartitionUtility[]

  @@unique([leaseId, moisFacture, typeUtility])
  @@index([leaseId])
  @@index([acteurId])
  @@index([statut])
  @@map("factures_utilities")
}

model RepartitionUtility {
  id                String        @id @default(uuid()) @map("repart_id")
  factureId         String        @map("facture_id")
  facture           FactureUtility @relation(fields: [factureId], references: [id])
  leaseLocataireId  String        @map("lease_locataire_id")
  leaseLocataire    Lease         @relation(fields: [leaseLocataireId], references: [id])
  locataireId       String        @map("locataire_id")
  locataire         User          @relation(fields: [locataireId], references: [id])
  montantQuotePart  Float       @map("montant_quote_part")
  modeleApplique    String @map("modele_applique")
  statutPaiement    String @default("EN_ATTENTE") @map("statut_paiement")
  dateNotification  DateTime?     @map("date_notification")
  datePaiement      DateTime?     @map("date_paiement")
  modePaiement      String?       @map("mode_paiement") // MOBILE_MONEY | CASH | WALLET_QAPRIL
  nbRelances        Int           @default(0) @map("nb_relances")
  createdAt         DateTime      @default(now()) @map("created_at")

  @@index([factureId])
  @@index([locataireId])
  @@map("repartitions_utilities")
}
