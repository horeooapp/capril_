model User {
  id          String  @id @default(uuid()) @map("user_id")
  phone       String? @unique
  fullName    String? @map("full_name")
  name        String?
  email       String? @unique
  role Role @default(TENANT)
  profileType ProfileType? @map("profile_type")
  kycLevel    Int     @default(0) @map("kyc_level") // 0-4
  kycStatus   String  @default("pending") @map("kyc_status") // pending|verified|under_review|expired|rejected
  status      String  @default("active") // active|suspended|inactive
  password    String?
  isCertified Boolean @default(false) @map("is_certified")
  onboardingComplete Boolean @default(false) @map("onboarding_complete")

  legalEntityId String?      @map("legal_entity_id")
  legalEntity   LegalEntity? @relation(fields: [legalEntityId], references: [id])

  preferredLang     String? @default("fr") @map("preferred_lang")
  notificationPrefs Json?   @map("notification_prefs")

  // MaPoste & Other
  maposteId String? @map("maposte_id")
  pushToken String? @map("push_token")

  // Relations
  identityDocuments     IdentityDocument[]
  propertiesOwned       Property[]          @relation("PropertyOwner")
  leasesAsLandlord      Lease[]             @relation("LeaseLandlord")
  leasesAsTenant        Lease[]             @relation("LeaseTenant")
  leasesAsAgent         Lease[]             @relation("LeaseAgent")
  legalEntitiesCreated  LegalEntity[]       @relation("EntityCreator")
  auditLogs             AuditLog[]
  notifications         Notification[]
  verifiedDocuments     IdentityDocument[]  @relation("DocumentVerifier")
  reliabilityScores     ReliabilityScore[]
  certificates          Certificate[]
  mandates              Mandate[]           @relation("AgentMandates")
  propertiesManaged     Property[]          @relation("AgentProperties")
  mediationMessages     MediationMessage[]
  prepaymentRequests    PrepaymentRequest[] @relation("TenantPrepayments")
  prepaymentValidations PrepaymentRequest[] @relation("LandlordValidations")

  colocataires   Colocataire[]
  mandateHistory MandateHistory[] @relation("MandateHistoryAgent")

  pgwPayerTransactions       PaymentPgw[]          @relation("PayerTransactions")
  pgwBeneficiaryTransactions PaymentPgw[]          @relation("BeneficiaryTransactions")
  coopGroups                 CoopGroup[]           @relation("CoopMembers")
  migrationSessions          MigrationSession[]
  reversalTransactions       ReversalTransaction[]

  // ADD-19 QAPRIL Diaspora Package
  diasporaAbonnement     Boolean   @default(false) @map("diaspora_abonnement")
  diasporaAbonnementSince DateTime?  @map("diaspora_abonnement_since")
  diasporaDevise         String    @default("FCFA") @map("diaspora_devise")
  diasporaStripeId       String?   @map("diaspora_stripe_id")
  diasporaWhatsapp       String?   @map("diaspora_whatsapp")
  paysResidence          String?   @map("pays_residence")
  fuseauHoraire          String    @default("Africa/Abidjan") @map("fuseau_horaire")
  emailRapportMensuel    String?   @map("email_rapport_mensuel")
  deviceFingerprint      String?   @map("device_fingerprint")
  fraudScore             Int       @default(0) @map("fraud_score")
  fraudFlags             Json?     @map("fraud_flags")

  // ADD-05 B2B & White Label
  whiteLabelConfig Json?   @map("white_label_config")
  companyRegNumber String? @map("company_reg_number")
  taxId            String? @map("tax_id")

  procurationsDonnees ProcurationNumerique[] @relation("Mandant")
  procurationsRecues  ProcurationNumerique[] @relation("Mandataire")
  fraudRecords        FraudBlacklist[]       @relation("UserFraud")
  blacklistAuthored   FraudBlacklist[]       @relation("BlacklistAuthor")

  // ADD-05 Freemium
  activePlanTier     String            @default("LOCATAIRE") @map("active_plan_tier")
  planExpiresAt      DateTime?           @map("plan_expires_at")
  subscriptionAudits SubscriptionAudit[]

  // ADD-09 Paywall (QAPRIL Wallet)
  walletBalance Int @default(0) @map("wallet_balance")

  // ADD-07 v3 Rechargement Automatique
  walletSeuilAlerte   Float? @default(500) @map("wallet_seuil_alerte")
  walletRappelActif   Boolean  @default(false) @map("wallet_rappel_actif")
  walletRappelJour    Int      @default(1) @map("wallet_rappel_jour")
  walletRappelMontant Float? @map("wallet_rappel_montant")
  walletOperateurPrefere String @default("WAVE") @map("wallet_operateur_prefere")
  walletCanalAlertePref String @default("WHATSAPP") @map("wallet_canal_alerte_pref")

  walletRechargeLinks  WalletRechargeLink[]
  walletRechargeConfig WalletRechargeConfig?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bailsDeclaratifsAsBailleur  BailDeclaratif[] @relation("BdqBailleur")
  bailsDeclaratifsAsLocataire BailDeclaratif[] @relation("BdqLocataire")
  bailsDeclaratifsAsAgent     BailDeclaratif[] @relation("BdqAgent")

  bdqConversations BdqConversationState[] @relation("BdqConvBailleur")

  // Relations ADD-03
  agentEdls            EtatsDesLieux[]         @relation("AgentEdls")
  locataireEdls        EtatsDesLieux[]         @relation("LocataireEdls")
  signatures           SignatureElectronique[]
  maintenanceDeclarant TicketMaintenance[]     @relation("MaintenanceDeclarant")
  userCandidatures     Candidature[]           @relation("UserCandidatures")
  agenceAnnonces       Annonce[]               @relation("AgenceAnnonces")
  proprietaireCrgs     CrgMensuel[]            @relation("ProprietaireCrgs")
  agenceCrgs           CrgMensuel[]            @relation("AgenceCrgs")
  agenceEvents         AgendaEvenement[]       @relation("AgenceEvents")
  agentEvents          AgendaEvenement[]       @relation("AgentEvents")
  eventContact         AgendaEvenement[]       @relation("EventContact")
  disputeMessages      DisputeMessage[]        @relation("DisputeSender")

  notificationPreference NotificationPreference?
  notificationLogs       NotificationLog[]

  // ADD-11
  propertyRoles      PropertyAccess[] @relation("UserRoles")
  invitedRoles       PropertyAccess[] @relation("InvitedRoles")
  smsDeclarations    SmsDeclaration[] @relation("TenantDeclarations")
  smsConfirmations   SmsDeclaration[] @relation("ManagerConfirmations")

  mandatsDonnes      MandatGestion[]  @relation("MandatsDonnes")
  mandatsRecus       MandatGestion[]  @relation("MandatsRecus")
  regularisation     AgencesRegularisation?
  gardeFousLogs      GardeFousLog[]   @relation("UserGardeFous")
  adminGardeFousLogs GardeFousLog[]   @relation("AdminGardeFous")

  // ADD-12 Tarifs
  configTarifsModifies ConfigTarif[]       @relation("ConfigTarifModifier")
  offresModifiees      OffreAbonnement[]   @relation("OffreModifier")
  promosCrees          CodePromo[]         @relation("PromoCreator")
  tarifsNegocies       TarifNegocie[]      @relation("UserTarifNegocie")
  tarifsNegociesCrees  TarifNegocie[]      @relation("TarifNegocieCreator")
  configTarifsAudits   ConfigTarifsAudit[] @relation("ConfigTarifAuditAuthor")

  // ADD-13 Espace Locataire
  locataireProfile       LocataireProfile?
  signalements           SignalementLocataire[] @relation("UserSignalements")
  preavis                PreavisBail[]          @relation("UserPreavis")
  passeports             PasseportLocatif[]     @relation("UserPasseports")
  alertesLoyer           AlerteLoyer[]          @relation("UserAlertesLoyer")

  // ADD-14
  profilPublic           LocataireProfilPublic?
  invitationsEnvoyees    InvitationBail[]       @relation("InvitantBail")
  invitationsRecues      InvitationBail[]       @relation("LocataireInvite")
  consultationsEffectuees ConsultationProfil[]   @relation("ConsultantProfil")

  // ADD-16 Succession
  successionsOwned       SuccessionProprio[]
  successionsAsTenant    SuccessionLocataire[] @relation("SuccessionAsTenant")
  reclamations           ReclamationLocataire[] @relation("TenantReclamations")
  
  // ADD-15 Rapports & Champions
  redactedEdls         EtatsDesLieux[]    @relation("RedacteurEdl")
  rapportsMensuels     RapportMensuel[]
  championProfile      ChampionProfile?
  supervisedChampions  ChampionProfile[]  @relation("SuperviseurChampions")
  prospectsConvertis   ChampionProspect[] @relation("ProspectConverti")

  // ADD-16 Succession Locataire
  // beneficiaireNom      String? @map("beneficiaire_nom")
  // beneficiaireLien     String? @map("beneficiaire_lien")
  // beneficiairePhone    String? @map("beneficiaire_phone")
  // beneficiaireDesignationAt DateTime? @map("beneficiaire_designation_at")

  // ADD-17 & 18 Relations
  messagesBailEnvoyes   MessagerieBail[]
  annoncesVoisinage     AnnonceVoisinage[]
  facturesUtilities     FactureUtility[]
  repartitionsUtilities RepartitionUtility[]

  @@index([phone])
  @@index([role])
  @@map("users")
}

// ═══════════════════════════════════════════════════════
// LEGAL ENTITIES (Part 5.1/Level 4)
// ═══════════════════════════════════════════════════════
model LegalEntity {
  id                String  @id @default(uuid()) @map("entity_id")
  createdByUserId   String  @map("created_by")
  creator           User    @relation("EntityCreator", fields: [createdByUserId], references: [id])
  companyName       String  @map("company_name")
  legalForm         String? @map("legal_form")
  rccmNumber        String  @map("rccm_number")
  nifNumber         String? @map("nif_number")
  registeredAddress String? @map("registered_address")
  activitySector    String? @map("activity_sector")
  bankAccount       String? @map("bank_account")
  status            String  @default("pending")

  bdqConversations BdqConversationState[] @relation("BdqConvLegalEntity")

  ownedLeases Lease[]            @relation("LandlordLeases")
  users       User[]
  leases      Lease[]            @relation("LeaseTenantEntity")
  documents   IdentityDocument[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("legal_entities")
}

// ═══════════════════════════════════════════════════════
// IDENTITY DOCUMENTS (Part 5.2)
// ═══════════════════════════════════════════════════════
model IdentityDocument {
  id     String @id @default(uuid()) @map("doc_id")
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  legalEntityId String?      @map("legal_entity_id")
  legalEntity   LegalEntity? @relation(fields: [legalEntityId], references: [id])

  docType          String    @map("doc_type") // CNI_CI|PASS_CI|RCCM|NIF|...
  docNumber        String    @map("doc_number")
  docNumberHash    String    @unique @map("doc_number_hash")
  fullName         String?   @map("full_name")
  birthDate        DateTime? @map("birth_date")
  nationality      String?
  issuingCountry   String?   @map("issuing_country")
  expiryDate       DateTime? @map("expiry_date")
  mrzRawData       String?   @map("mrz_raw_data")
  scanS3Key        String?   @map("scan_s3_key")
  status           String    @default("pending") // pending|verified|under_review|expired|rejected
  verifiedAt       DateTime? @map("verified_at")
  verifiedByUserId String?   @map("verified_by")
  verifier         User?     @relation("DocumentVerifier", fields: [verifiedByUserId], references: [id])
  rejectionReason  String?   @map("rejection_reason")
  metadata         Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("identity_documents")
}

// ═══════════════════════════════════════════════════════
// PROPERTIES (Part 6)
// ═══════════════════════════════════════════════════════
model Property {
  id                   String   @id @default(uuid()) @map("property_id")
  propertyCode         String   @unique @map("property_code") // HAB-ABJ-YOP-00001
  ownerUserId          String   @map("owner_id")
  owner                User     @relation("PropertyOwner", fields: [ownerUserId], references: [id])
  propertyType         String   @map("property_type") // apartment|house|studio|villa|room|commercial
  leaseType            String   @default("residential") @map("lease_type") // residential|commercial
  commune              String
  address              String
  areaSqm              Float? @map("area_sqm")
  rooms                Int?
  bedrooms             Int?
  name                 String?  @map("name")
  city                 String?  @map("city")
  declaredRentFcfa     Float? @map("declared_rent_fcfa")
  digitalPostalAddress String?  @map("digital_postal_address")
  gpsLatitude          Float? @map("gps_latitude")
  gpsLongitude         Float? @map("gps_longitude")
  amenities String @default("[]")
  status               String   @default("draft") // draft|pending_verification|active|rented|suspended|rejected|archived
  documents            Json?

  verifiedAt       DateTime? @map("verified_at")
  verifiedByUserId String?   @map("verified_by")

  managedByUserId String? @map("managed_by")
  manager         User?   @relation("AgentProperties", fields: [managedByUserId], references: [id])

  managementMode    String @default("DIRECT") @map("management_mode")
  superficieM2      Float?       @map("superficie_m2")
  usageTerrain      String?  @map("usage_terrain")
  referenceCadastre String?        @map("reference_cadastre")

  leases           Lease[]
  bailsDeclaratifs BailDeclaratif[]
  mandates         Mandate[]
  passports        Passport[]
  images           PropertyImage[]
  invitations      InvitationBail[]

  // ADD-05 Horeoo
  isHoreoo       Boolean  @default(false) @map("is_horeoo")
  horeooDiscount Float? @map("horeoo_discount")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations ADD-03
  ticketsMaintenance TicketMaintenance[]
  candidatures       Candidature[]
  chargesParametrage ChargeParametrage[]
  annonces           Annonce[]
  agendaEvents       AgendaEvenement[]

  // Phase 10: Assets & Intelligence
  maintenanceRecords PropertyMaintenance[]
  technicalDocuments PropertyDocument[]

  sourceMigrationId String?           @map("source_migration_id")
  sourceMigration   MigrationSession? @relation(fields: [sourceMigrationId], references: [id])

  // ADD-11
  accessRoles PropertyAccess[] @relation("PropertyRoles")

  // ADD-17 & 18
  annoncesVoisinage AnnonceVoisinage[]

  @@index([ownerUserId])
  @@index([commune])
  @@index([status])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id])
  s3Key      String   @map("s3_key")
  isMain     Boolean  @default(false) @map("is_main")

  @@map("property_images")
}

// ═══════════════════════════════════════════════════════
// LEASES (Part 7 & 8)
// ═══════════════════════════════════════════════════════
model Lease {
  id               String       @id @default(uuid()) @map("lease_id")
  leaseReference   String       @unique @map("lease_reference") // BAIL-2026-00123
  propertyId       String       @map("property_id")
  property         Property     @relation(fields: [propertyId], references: [id])
  landlordId       String       @map("landlord_id")
  landlord         User         @relation("LeaseLandlord", fields: [landlordId], references: [id])
  landlordEntityId String?      @map("landlord_entity_id")
  landlordEntity   LegalEntity? @relation("LandlordLeases", fields: [landlordEntityId], references: [id])
  tenantId         String?      @map("tenant_id")
  tenant           User?        @relation("LeaseTenant", fields: [tenantId], references: [id])
  tenantEntityId   String?      @map("tenant_entity_id")
  tenantEntity     LegalEntity? @relation("LeaseTenantEntity", fields: [tenantEntityId], references: [id])
  agentId          String?      @map("agent_id")
  agent            User?        @relation("LeaseAgent", fields: [agentId], references: [id])
  mandateId        String?      @map("mandate_id")
  mandate          Mandate?     @relation(fields: [mandateId], references: [id])
  leaseType        String       @default("residential") @map("lease_type") // residential|commercial

  startDate      DateTime  @map("start_date")
  endDate        DateTime? @map("end_date")
  durationMonths Int       @map("duration_months")
  rentAmount     Int       @map("rent_amount") // FCFA entiers
  chargesAmount  Int       @default(0) @map("charges_amount")
  paymentDay     Int       @default(5) @map("payment_day")
  depositAmount  Int       @default(0) @map("deposit_amount")
  
  // NOUVEAUX CHAMPS — Pratique locative CI (DLP-001)
  dateLimitePaiement Int     @default(5) @map("date_limite_paiement") // Jour du mois avant lequel le loyer est dû (ex: 5, 10, personalized)
  paiementAvance     Boolean @default(true) @map("paiement_avance")    // TRUE = payé d'avance (standard CI)

  typeGestion    String? @default("directe") @map("type_gestion")
  bailleurMasque Boolean @default(false) @map("bailleur_masque")

  status     String @default("DRAFT")
  importMode Boolean     @default(false) @map("import_mode")

  // ADD-05 BDQ
  typeBail                 String  @default("ECRIT") @map("type_bail")
  confirmationLocataireSms Boolean   @default(false) @map("confirmation_locataire_sms")
  confirmationLocataireAt  DateTime? @map("confirmation_locataire_at")
  preavisRequisMois        Int?      @default(1) @map("preavis_requis_mois")

  signedAt          DateTime? @map("signed_at")
  terminatedAt      DateTime? @map("terminated_at")
  terminationReason String?   @map("termination_reason")

  commercialData Json? @map("commercial_data") // Indexation settings, company name, etc.

  receipts        Receipt[]
  arrears         LeaseArrear[]
  cdcDeposits     CDCDeposit[]
  disputes        Dispute[]
  incidentLogs    Incident[]
  procedurePhases ProcedurePhase[]
  insurance       Insurance?
  repaymentPlans  RepaymentPlan[]
  mediation       Mediation?
  paymentIntents  PaymentIntent[]
  fiscalDossiers  FiscalDossier[]
  prepayments     PrepaymentRequest[]
  pgwPayments     PaymentPgw[]

  colocataires Colocataire[]
  bdq          BailDeclaratif? @relation("BdqFormalise")

  // Relations ADD-03
  etatsDesLieux          EtatsDesLieux[]
  ticketsMaintenance     TicketMaintenance[]
  regularisationsCharges RegularisationCharges[]
  agendaEvents           AgendaEvenement[]

  synthesesLoyer  MonthlyRentSynthesis[]
  landInfo        LandLeaseInfo?
  legalProcedures LegalProcedure[]
  coopGroup       CoopGroup?

  // M-SIG-ELEC
  isSignedElectronically Boolean @default(false) @map("is_signed_electronically")
  signingOtp             String? @map("signing_otp")
  signatureContext       Json?   @map("signature_context") // {ip, ua, loc}

  // M-EDL
  inspections Inspection[]

  // M-RECOUVREMENT
  reminders ReminderLog[]

  // ADD-18 Utilities
  modeUtilities     String @default("NON_APPLICABLE") @map("mode_utilities")
  identifiantCie    String?     @map("identifiant_cie")
  identifiantSodeci String?     @map("identifiant_sodeci")
  modeleRepartition String @default("PRORATA_CHAMBRE") @map("modele_repartition")
  forfaitUtilitiesMensuel Float? @map("forfait_utilities_mensuel")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sourceMigrationId String?           @map("source_migration_id")
  sourceMigration   MigrationSession? @relation(fields: [sourceMigrationId], references: [id])

  // ADD-11
  smsDeclarations SmsDeclaration[] @relation("LeaseDeclarations")

  // ADD-13 Espace Locataire
  signalements           SignalementLocataire[]
  caution                CautionBail?
  preavis                PreavisBail[]
  alertesLoyer           AlerteLoyer[]
  
  // ADD-16 Succession & Litige
  successions            SuccessionLocataire[]
  reclamations           ReclamationLocataire[]
  dossiersLitige         DossierLitigeCertifie[]
  propositionsLoyer      PropositionLoyer[]

  // ADD-17 & 18 Relations
  messagesBail            MessagerieBail[]
  facturesUtilities       FactureUtility[]
  repartitionsUtilities   RepartitionUtility[]

  // ADD-01 v2 M-FISCAL
  nbPagesBail            Int?      @map("nb_pages_bail")
  dureeMoisBail          Int?      @map("duree_mois_bail")
  loyerTotalFcfa         Float?  @map("loyer_total_fcfa")
  droitsEnregistrement   Float?  @map("droits_enregistrement")
  fraisTimbre            Float?  @map("frais_timbre")
  totalFiscalBail        Float?  @map("total_fiscal_bail")
  statutFiscal           String    @default("NON_CALCULÉ") @map("statut_fiscal")
  recuFiscalUrl          String?   @map("recu_fiscal_url")
  recuFiscalHash         String?   @map("recu_fiscal_hash")
  deadlineEnregistrement DateTime? @map("deadline_enregistrement")
  certEnregistrementDgiUrl String? @map("cert_enregistrement_dgi_url")

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
  @@map("leases")
}

// ═══════════════════════════════════════════════════════
// RECEIPTS & PAYMENTS (Part 9)
// ═══════════════════════════════════════════════════════
model PaymentIntent {
  id             String  @id @default(uuid())
  idempotencyKey String  @unique @map("idempotency_key")
  leaseId        String  @map("lease_id")
  lease          Lease   @relation(fields: [leaseId], references: [id])
  amount         Int
  operator       String // orange|mtn|moov|wave
  operatorRef    String? @map("operator_ref")
  payerPhone     String  @map("payer_phone")
  status         String  @default("pending") // pending|success|failed
  metadata       Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payment_intents")
}

model Receipt {
  id            String       @id @default(uuid()) @map("receipt_id")
  receiptRef    String       @unique @map("receipt_ref") // REC-2026-04-00123AB (or QR- format)
  leaseId       String       @map("lease_id")
  lease         Lease        @relation(fields: [leaseId], references: [id])
  periodMonth   String       @map("period_month") // YYYY-MM
  rentAmount    Int          @map("rent_amount")
  chargesAmount Int          @default(0) @map("charges_amount")
  totalAmount   Int          @map("total_amount")
  paymentMethod String       @map("payment_method") // MOBILE_MONEY|CASH|BANK_TRANSFER
  paymentRef    String?      @map("payment_ref")
  paidAt        DateTime?    @map("paid_at")
  pdfUrl        String?      @map("pdf_url")
  qrToken       String?      @unique @map("qr_token")
  receiptHash   String?      @map("receipt_hash") // SHA256 of contents
  status        String       @default("pending") // pending|paid|cancelled|disputed
  declarative   Boolean      @default(false) @map("declarative")
  pgwPayments   PaymentPgw[]

  digitalDeliveryId String?          @map("digital_delivery_id")
  delivery          DigitalDelivery? @relation(fields: [digitalDeliveryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([leaseId])
  @@index([periodMonth])
  @@map("receipts")
}

// ═══════════════════════════════════════════════════════
// ARREARS & PROCEDURES (Part 11)
// ═══════════════════════════════════════════════════════
model LeaseArrear {
  id      String   @id @default(uuid())
  leaseId String   @map("lease_id")
  lease   Lease    @relation(fields: [leaseId], references: [id])
  dueDate DateTime @map("due_date")
  amount  Int
  status  String   @default("unpaid") // unpaid|paid|partial|waived

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dueDate, status])
  @@map("lease_arrears")
}

model ProcedurePhase {
  id          String   @id @default(uuid())
  leaseId     String   @map("lease_id")
  lease       Lease    @relation(fields: [leaseId], references: [id])
  phaseNumber Int      @map("phase_number")
  name        String
  description String?
  actionDate  DateTime @default(now()) @map("action_date")
  metadata    Json?

  @@map("procedure_phases")
}

// ═══════════════════════════════════════════════════════
// CDC DEPOSIT (Part 10)
// ═══════════════════════════════════════════════════════
model CDCDeposit {
  id           String              @id @default(uuid())
  leaseId      String              @unique @map("lease_id")
  lease        Lease               @relation(fields: [leaseId], references: [id])
  amount       Int
  initiator    String @default("OWNER")
  cdcReference String?             @map("cdc_reference")
  status       String    @default("AWAITING_PAYMENT")
  proofHash    String?             @map("proof_hash")
  consignedAt  DateTime?           @map("consigned_at")
  returnedAt   DateTime?           @map("returned_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cdc_deposits")
}

// ═══════════════════════════════════════════════════════
// MANDATES (Part 12)
// ═══════════════════════════════════════════════════════
model Mandate {
  id              String        @id @default(uuid())
  mandateRef      String        @unique @map("mandate_ref")
  propertyId      String        @map("property_id")
  property        Property      @relation(fields: [propertyId], references: [id])
  agentUserId     String?       @map("agent_id")
  agent           User?         @relation("AgentMandates", fields: [agentUserId], references: [id])
  mandateType     String
  commissionPct   Float?      @map("commission_pct")
  commissionFixed Int?          @map("commission_fixed")
  startDate       DateTime      @map("start_date")
  endDate         DateTime?     @map("end_date")
  status          String @default("DRAFT")
  scope String @default("[]") // List of units or total

  signedAt          DateTime? @map("signed_at")
  cancelledAt       DateTime? @map("cancelled_at")
  cancelledByUserId String?   @map("cancelled_by")
  cancelReason      String?   @map("cancel_reason")

  proofHash String? @map("proof_hash")
  pdfUrl    String? @map("pdf_url")

  leases  Lease[]
  history MandateHistory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("mandates")
}

model MandateHistory {
  id               String      @id @default(uuid())
  propertyId       String      @map("property_id")
  mandateId        String      @map("mandate_id")
  mandate          Mandate     @relation(fields: [mandateId], references: [id])
  agentUserId      String?     @map("agent_id")
  agent            User?       @relation("MandateHistoryAgent", fields: [agentUserId], references: [id])
  mandateType      String @map("type_mandat")
  startDate        DateTime    @map("periode_debut")
  endDate          DateTime?   @map("periode_fin")
  bailsTransferred Int?        @map("baux_actifs_transferes")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("mandate_history")
}

model Colocataire {
  id           String    @id @default(uuid()) @map("coloc_id")
  leaseId      String    @map("bail_id")
  lease        Lease     @relation(fields: [leaseId], references: [id])
  userId       String    @map("user_id")
  user         User      @relation(fields: [userId], references: [id])
  role ColocRole @default(SECONDAIRE)
  partLoyer    Int?      @map("part_loyer")
  pctLoyer     Float?  @map("pct_loyer")
  modePaiement String @default("INDIVIDUEL") @map("mode_paiement")
  dateEntree   DateTime  @map("date_entree")
  dateSortie   DateTime? @map("date_sortie")
  status       String    @default("ACTIF") // ACTIF | SORTI | EXCLU

  payments  ColocPayment[]
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([leaseId])
  @@index([userId])
  @@map("colocataires")
}

model ColocPayment {
  id            String      @id @default(uuid()) @map("id")
  leaseId       String      @map("bail_id")
  colocataireId String      @map("coloc_id")
  colocataire   Colocataire @relation(fields: [colocataireId], references: [id])
  month         String      @map("mois_concerne") // YYYY-MM
  amount        Int         @map("montant_paye")
  method        String      @map("canal_paiement")
  status        String      @default("CONFIRMED")
  operatorRef   String?     @map("reference_mobile")
  receiptId     String?     @map("quittance_ind_id")

  paidAt DateTime @default(now()) @map("paid_at")

  @@index([leaseId, month])
  @@map("coloc_payments")
}

model MonthlyRentSynthesis {
  id              String      @id @default(uuid()) @map("synthese_id")
  leaseId         String      @map("bail_id")
  lease           Lease       @relation(fields: [leaseId], references: [id])
  month           String      @map("mois_concerne") // YYYY-MM
  totalExpected   Int         @map("loyer_total_du")
  amountCollected Int         @default(0) @map("montant_collecte")
  status          String @default("EN_ATTENTE") @map("statut_mois")
  globalReceiptId String?     @map("quittance_glob_id")
  completedAt     DateTime?   @map("completed_at")

  @@unique([leaseId, month])
  @@map("monthly_rent_synthesis")
}

model LandLeaseInfo {
  id                String       @id @default(uuid())
  leaseId           String       @unique @map("bail_id")
  lease             Lease        @relation(fields: [leaseId], references: [id])
  superficieLouee   Float      @map("superficie_louee_m2")
  usage             String @map("usage_declare")
  periodicity       String  @default("MENSUEL") @map("periodicite_loyer")
  eventEndDate      DateTime?    @map("date_evenement_fin")
  annualIndexation  Float?     @default(0) @map("indexation_annuelle")
  conditions        String?      @map("conditions_usage")
  hasEntryInventory Boolean      @default(false) @map("etat_des_lieux_entree")
  hasExitInventory  Boolean      @default(false) @map("etat_des_lieux_sortie")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("land_lease_info")
}

// ═══════════════════════════════════════════════════════
// SCORING & CERTIFICATES (Part 13 & 14)
// ═══════════════════════════════════════════════════════
model ReliabilityScore {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  user      User   @relation(fields: [userId], references: [id])
  score     Int // 0-100
  grade     String // A|B|C|D|E|F
  breakdown Json // payment_timeliness, payment_completeness, etc.

  createdAt DateTime @default(now()) @map("created_at")

  @@map("reliability_scores")
}

model Certificate {
  id        String   @id @default(uuid()) @map("cert_id")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  certType  String   @map("cert_type") // CNL (Certificat Numérique Locataire)
  issuedAt  DateTime @default(now()) @map("issued_at")
  expiresAt DateTime @map("expires_at")
  qrToken   String   @unique @map("qr_token")
  pdfUrl    String?  @map("pdf_url")
  status    String   @default("valid") // valid|expired|revoked

  @@map("certificates")
}

model Passport {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id])
  content    Json // Immutable facts about property history

  createdAt DateTime @default(now()) @map("created_at")

  @@map("passports")
}

// ═══════════════════════════════════════════════════════
// DISPUTES & MEDIATION (Part 16)
// ═══════════════════════════════════════════════════════
model Dispute {
  id              String        @id @default(uuid())
  leaseId         String        @map("lease_id")
  lease           Lease         @relation(fields: [leaseId], references: [id])
  title           String
  description     String
  amountInDispute Int?          @map("amount_in_dispute")
  status          String @default("OPEN")
  resolution      String?

  messages DisputeMessage[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("disputes")
}

model DisputeMessage {
  id          String   @id @default(uuid())
  disputeId   String   @map("dispute_id")
  dispute     Dispute  @relation(fields: [disputeId], references: [id])
  senderId    String   @map("sender_id")
  sender      User     @relation("DisputeSender", fields: [senderId], references: [id])
  content     String
  attachments String @default("[]")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("dispute_messages")
}

// ═══════════════════════════════════════════════════════
// INTEGRATIONS & SYSTEM (Part 17, 19, 20, 23)
// ═══════════════════════════════════════════════════════
model DigitalDelivery {
  id             String    @id @default(uuid())
  trackingNumber String    @unique @map("tracking_number") // CI-POST-2026-00123
  deliveryMode   String    @map("delivery_mode") // maposte_number|physical_address|post_office
  status         String    @default("submitted") // submitted|in_transit|delivered|failed|returned
  recipientData  Json      @map("recipient_data")
  deliveredAt    DateTime? @map("delivered_at")

  receipts Receipt[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("digital_deliveries")
}

model Notification {
  id         String  @id @default(uuid())
  userId     String  @map("user_id")
  user       User    @relation(fields: [userId], references: [id])
  channel    String  @default("PUSH") // SMS|PUSH|EMAIL|WHATSAPP|USSD_PUSH|COURRIER
  title      String?
  content    String
  type       String  @default("INFO")
  link       String?
  status     String  @default("pending") // pending|sent|delivered|failed
  read       Boolean @default(false)
  retryCount Int     @default(0) @map("retry_count")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model ObservatorySnapshot {
  id           String  @id @default(uuid())
  commune      String
  propertyType String  @map("property_type")
  period       String // YYYY-QX
  avgRent      Int     @map("avg_rent")
  medianRent   Int     @map("median_rent")
  minRent      Int     @map("min_rent")
  maxRent      Int     @map("max_rent")
  sampleCount  Int     @map("sample_count")
  trendPct     Float @map("trend_pct")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([commune, period])
  @@map("observatory_snapshots")
}

model MarketData {
  id           String @id @default(uuid())
  city         String
  commune      String
  propertyType String @map("property_type")
  averageRent  Float  @map("average_rent")
  sampleSize   Int    @map("sample_size")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([city, commune, propertyType], name: "city_commune_propertyType")
  @@map("market_data")
}

// ═══════════════════════════════════════════════════════
// ADD-16 SUCCESSION & LITIGE (Phase 3)
// ═══════════════════════════════════════════════════════

model SuccessionProprio {
  id              String   @id @default(uuid()) @map("succession_id")
  landlordId      String   @map("landlord_id")
  landlord        User     @relation(fields: [landlordId], references: [id])
  declarantNom    String   @map("declarant_nom")
  declarantLien   String   @map("declarant_lien") // heritier | notaire | locataire | autre
  declarantPhone  String   @map("declarant_phone")
  dateDeclaration DateTime @default(now()) @map("date_declaration")
  statut          String   @default("EN_COURS") // EN_COURS | VERIFIE | TRANSFERE | ARCHIVE | REJETE
  dateDeces       DateTime @map("date_deces")
  acteDecesUrl    String?  @map("acte_deces_url")
  heritierId      String?  @map("heritier_id")
  dateTransfert   DateTime? @map("date_transfert")
  notes           String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("successions_proprio")
}

model SuccessionLocataire {
  id              String   @id @default(uuid()) @map("succession_id")
  leaseId         String   @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  tenantId        String   @map("tenant_id")
  tenant          User     @relation("SuccessionAsTenant", fields: [tenantId], references: [id])
  dateDeces       DateTime @map("date_deces")
  declarantType   String?  @map("declarant_type") // proprio | famille | beneficiaire | autre
  declarantPhone  String?  @map("declarant_phone")
  
  beneficiaireId  String?  @map("beneficiaire_id") // Link to internal User if exists
  beneficiaireExtNom   String? @map("beneficiaire_ext_nom")
  beneficiaireExtPhone String? @map("beneficiaire_ext_phone")
  
  loyerProrata    Float? @map("loyer_prorata")
  cautionMontant  Float? @map("caution_montant")
  cautionRestituee Boolean @default(false) @map("caution_restituee")
  dateRestitution DateTime? @map("date_restitution")
  
  statut          String   @default("TRANSITION") // TRANSITION | CAUTION_TRAITEE | ARCHIVE | LITIGE
  dateFinTransition DateTime @map("date_fin_transition") // J+30 manual handle or auto
  notes           String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("successions_locataire")
}

model ReclamationLocataire {
  id              String   @id @default(uuid()) @map("reclamation_id")
  leaseId         String   @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  tenantId        String   @map("tenant_id")
  tenant          User     @relation("TenantReclamations", fields: [tenantId], references: [id])
  typeReclamation String   @map("type_reclamation") // RCL-01 | RCL-02 | RCL-03 | RCL-04
  description     String
  preuveUrl       String?  @map("preuve_url")
  statut          String   @default("OUVERT") // OUVERT | EN_COURS | RESOLU | ESCALADE_CACI | REJETE
  dateEcheance    DateTime @map("date_echeance")
  
  dossierLitigeId String?  @map("dossier_litige_id")
  dossierLitige   DossierLitigeCertifie? @relation(fields: [dossierLitigeId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("reclamations_locataire")
}

model DossierLitigeCertifie {
  id              String   @id @default(uuid()) @map("dlc_id")
  leaseId         String   @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  uuid            String   @unique @default(uuid()) @map("dlc_uuid")
  hashSha256      String   @map("dlc_hash_sha256")
  statut          String   @default("GENERE") // GENERE | TRANSMIS_CACI | MEDIATION_EN_COURS | CLOTURE
  refCaci         String?  @map("ref_caci")
  issue           String?  // ACCORD_AMIABLE | SENTENCE_ARBITRALE | ABANDONNE
  dateCloture     DateTime? @map("date_cloture")
  notes           String?

  reclamations    ReclamationLocataire[]
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("dossiers_litige_certifies")
}

model PropositionLoyer {
  id              String   @id @default(uuid()) @map("prop_id")
  leaseId         String   @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  montantActuel   Int      @map("montant_actuel")
  nouveauMontant  Int      @map("nouveau_montant")
  dateEffet       DateTime @map("date_effet")
  raison          String?
  statut          String   @default("EN_ATTENTE") // EN_ATTENTE | ACCEPTE | REFUSE | EXPIRE
  
  consentement    ConsentementLoyer?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("propositions_loyer")
}

model ConsentementLoyer {
  id              String   @id @default(uuid()) @map("consent_id")
