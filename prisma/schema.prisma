generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ANAH_AGENT
  CDC_AGENT
  LANDLORD
  LANDLORD_PRO
  AGENCY
  TENANT
  NON_CERTIFIED_AGENT
}

enum CDCDepositStatus {
  AWAITING_PAYMENT
  PENDING
  CONSIGNED
  RETURN_REQUESTED
  RETURNED
  FORFEITED
}

enum CDCDepositInitiator {
  OWNER
  AGENCY
  ADMIN
}

enum LeaseStatus {
  DRAFT
  PENDING_SIGNATURE
  PENDING_DEPOSIT
  ACTIVE
  LOYER_IMPAYE
  MISE_EN_DEMEURE
  CLEMENCE_EN_COURS
  REPRISE_PROCEDURE
  DEMANDE_RESILIATION
  TERMINATED
  CANCELLED
  ARCHIVED
}

enum PlanStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  BROKEN
  COMPLETED
}

enum InsuranceStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum InsuranceClaimStatus {
  OPEN
  PROCESSING
  RESOLVED
  REJECTED
}

enum MediationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  WAITING_RESPONSE
  IN_MEDIATION
  RESOLVED
  ESCALATED
  CLOSED
}

enum FiscalStatus {
  EN_ATTENTE_DECLARATION
  NOTIFIE
  EN_COURS_PAIEMENT
  PAYE_CONFIRME
  ENREGISTRE
  ECHEC_PAIEMENT
  PAIEMENT_PARTIEL
  DECLARATION_EN_RETARD
  IGNORE_PAR_BAILLEUR
  RENOUVELE
}

// ═══════════════════════════════════════════════════════
// USERS (Part 4 & 5)
// ═══════════════════════════════════════════════════════
model User {
  id                      String    @id @default(uuid()) @map("user_id")
  phone                   String    @unique
  fullName                String?   @map("full_name")
  email                   String?
  role                    Role      @default(TENANT)
  kycLevel                Int       @default(0) @map("kyc_level") // 0-4
  kycStatus               String    @default("pending") @map("kyc_status") // pending|verified|under_review|expired|rejected
  status                  String    @default("active") // active|suspended|inactive
  password                String?
  isCertified             Boolean   @default(false) @map("is_certified")
  
  legalEntityId           String?   @map("legal_entity_id")
  legalEntity             LegalEntity? @relation(fields: [legalEntityId], references: [id])
  
  preferredLang           String?   @default("fr") @map("preferred_lang")
  notificationPrefs       Json?     @default("{}") @map("notification_prefs")
  
  // MaPoste & Other
  maposteId               String?   @map("maposte_id")
  pushToken               String?   @map("push_token")
  
  // Relations
  identityDocuments       IdentityDocument[]
  propertiesOwned         Property[]         @relation("PropertyOwner")
  leasesAsLandlord        Lease[]            @relation("LeaseLandlord")
  leasesAsTenant          Lease[]            @relation("LeaseTenant")
  leasesAsAgent           Lease[]            @relation("LeaseAgent")
  legalEntitiesCreated    LegalEntity[]      @relation("EntityCreator")
  auditLogs               AuditLog[]
  notifications           Notification[]
  verifiedDocuments       IdentityDocument[] @relation("DocumentVerifier")
  reliabilityScores       ReliabilityScore[]
  certificates            Certificate[]
  mandates                Mandate[]         @relation("AgentMandates")
  propertiesManaged       Property[]        @relation("AgentProperties")
  mediationMessages       MediationMessage[]

  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("users")
  @@index([phone])
  @@index([role])
}

// ═══════════════════════════════════════════════════════
// LEGAL ENTITIES (Part 5.1/Level 4)
// ═══════════════════════════════════════════════════════
model LegalEntity {
  id                String   @id @default(uuid()) @map("entity_id")
  createdByUserId   String   @map("created_by")
  creator           User     @relation("EntityCreator", fields: [createdByUserId], references: [id])
  companyName       String   @map("company_name")
  legalForm         String?  @map("legal_form")
  rccmNumber        String   @map("rccm_number")
  nifNumber         String?  @map("nif_number")
  registeredAddress String?  @map("registered_address")
  activitySector    String?  @map("activity_sector")
  bankAccount       String?  @map("bank_account")
  status            String   @default("pending")
  
  users             User[]
  leases            Lease[]           @relation("LeaseTenantEntity")
  documents         IdentityDocument[]

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("legal_entities")
}

// ═══════════════════════════════════════════════════════
// IDENTITY DOCUMENTS (Part 5.2)
// ═══════════════════════════════════════════════════════
model IdentityDocument {
  id              String    @id @default(uuid()) @map("doc_id")
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id])
  
  legalEntityId   String?   @map("legal_entity_id")
  legalEntity     LegalEntity? @relation(fields: [legalEntityId], references: [id])

  docType         String    @map("doc_type") // CNI_CI|PASS_CI|RCCM|NIF|...
  docNumber       String    @map("doc_number")
  docNumberHash   String    @unique @map("doc_number_hash")
  fullName        String?   @map("full_name")
  birthDate       DateTime? @map("birth_date") @db.Date
  nationality     String?   @db.Char(3)
  issuingCountry  String?   @map("issuing_country") @db.Char(3)
  expiryDate      DateTime? @map("expiry_date") @db.Date
  mrzRawData      String?   @map("mrz_raw_data")
  scanS3Key       String?   @map("scan_s3_key")
  status          String    @default("pending") // pending|verified|under_review|expired|rejected
  verifiedAt      DateTime? @map("verified_at")
  verifiedByUserId String?  @map("verified_by")
  verifier        User?     @relation("DocumentVerifier", fields: [verifiedByUserId], references: [id])
  rejectionReason String?   @map("rejection_reason")
  metadata        Json?      @default("{}")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("identity_documents")
}

// ═══════════════════════════════════════════════════════
// PROPERTIES (Part 6)
// ═══════════════════════════════════════════════════════
model Property {
  id                String   @id @default(uuid()) @map("property_id")
  propertyCode      String   @unique @map("property_code") // HAB-ABJ-YOP-00001
  ownerUserId       String   @map("owner_id")
  owner             User     @relation("PropertyOwner", fields: [ownerUserId], references: [id])
  propertyType      String   @map("property_type") // apartment|house|studio|villa|room|commercial
  leaseType         String   @default("residential") @map("lease_type") // residential|commercial
  commune           String
  address           String   @db.Text
  areaSqm           Decimal? @map("area_sqm") @db.Decimal(8, 2)
  rooms             Int?     @db.SmallInt
  bedrooms          Int?     @db.SmallInt
  name              String?  @map("name")
  city              String?  @map("city")
  declaredRentFcfa  Decimal? @map("declared_rent_fcfa") @db.Decimal(12, 2)
  digitalPostalAddress String? @map("digital_postal_address")
  gpsLatitude       Decimal? @map("gps_latitude") @db.Decimal(10, 8)
  gpsLongitude      Decimal? @map("gps_longitude") @db.Decimal(11, 8)
  amenities         String[]
  status            String   @default("draft") // draft|pending_verification|active|rented|suspended|rejected|archived
  documents         Json?    @default("{}")
  
  verifiedAt        DateTime? @map("verified_at")
  verifiedByUserId  String?   @map("verified_by")
  
  managedByUserId   String?   @map("managed_by")
  manager           User?     @relation("AgentProperties", fields: [managedByUserId], references: [id])

  leases            Lease[]
  mandates          Mandate[]
  passports         Passport[]
  images            PropertyImage[]

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("properties")
  @@index([ownerUserId])
  @@index([commune])
  @@index([status])
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id])
  s3Key      String   @map("s3_key")
  isMain     Boolean  @default(false) @map("is_main")
  
  @@map("property_images")
}

// ═══════════════════════════════════════════════════════
// LEASES (Part 7 & 8)
// ═══════════════════════════════════════════════════════
model Lease {
  id                String   @id @default(uuid()) @map("lease_id")
  leaseReference    String   @unique @map("lease_reference") // BAIL-2026-00123
  propertyId        String   @map("property_id")
  property          Property @relation(fields: [propertyId], references: [id])
  landlordId        String   @map("landlord_id")
  landlord          User     @relation("LeaseLandlord", fields: [landlordId], references: [id])
  tenantId          String?  @map("tenant_id")
  tenant            User?    @relation("LeaseTenant", fields: [tenantId], references: [id])
  tenantEntityId    String?  @map("tenant_entity_id")
  tenantEntity      LegalEntity? @relation("LeaseTenantEntity", fields: [tenantEntityId], references: [id])
  agentId           String?  @map("agent_id")
  agent             User?    @relation("LeaseAgent", fields: [agentId], references: [id])
  mandateId         String?  @map("mandate_id")
  mandate           Mandate? @relation(fields: [mandateId], references: [id])
  leaseType         String   @default("residential") @map("lease_type") // residential|commercial
  
  startDate         DateTime @map("start_date") @db.Date
  endDate           DateTime? @map("end_date") @db.Date
  durationMonths    Int      @map("duration_months") @db.SmallInt
  rentAmount        Int      @map("rent_amount") // FCFA entiers
  chargesAmount     Int      @default(0) @map("charges_amount")
  paymentDay        Int      @default(5) @map("payment_day") @db.SmallInt
  depositAmount     Int      @default(0) @map("deposit_amount")
  
  status            LeaseStatus @default(DRAFT)
  importMode        Boolean  @default(false) @map("import_mode")
  
  signedAt          DateTime? @map("signed_at")
  terminatedAt      DateTime? @map("terminated_at")
  terminationReason String?   @map("termination_reason") @db.Text
  
  commercialData    Json?     @map("commercial_data") // Indexation settings, company name, etc.
  
  receipts          Receipt[]
  arrears           LeaseArrear[]
  cdcDeposits       CDCDeposit[]
  disputes          Dispute[]
  incidentLogs      Incident[]
  procedurePhases   ProcedurePhase[]
  insurance         Insurance?
  repaymentPlans    RepaymentPlan[]
  mediation         Mediation?
  paymentIntents    PaymentIntent[]
  fiscalDossiers    FiscalDossier[]

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("leases")
  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════
// RECEIPTS & PAYMENTS (Part 9)
// ═══════════════════════════════════════════════════════
model PaymentIntent {
  id                String   @id @default(uuid())
  idempotencyKey    String   @unique @map("idempotency_key")
  leaseId           String   @map("lease_id")
  lease             Lease    @relation(fields: [leaseId], references: [id])
  amount            Int
  operator          String // orange|mtn|moov|wave
  operatorRef       String?  @map("operator_ref")
  payerPhone        String   @map("payer_phone")
  status            String   @default("pending") // pending|success|failed
  metadata          Json?
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("payment_intents")
}

model Receipt {
  id                String   @id @default(uuid()) @map("receipt_id")
  receiptRef        String   @unique @map("receipt_ref") // REC-2026-04-00123AB (or QR- format)
  leaseId           String   @map("lease_id")
  lease             Lease    @relation(fields: [leaseId], references: [id])
  periodMonth       String   @map("period_month") // YYYY-MM
  rentAmount        Int      @map("rent_amount")
  chargesAmount     Int      @default(0) @map("charges_amount")
  totalAmount       Int      @map("total_amount")
  paymentMethod     String   @map("payment_method") // MOBILE_MONEY|CASH|BANK_TRANSFER
  paymentRef        String?  @map("payment_ref")
  paidAt            DateTime? @map("paid_at")
  pdfUrl            String?  @map("pdf_url")
  qrToken           String?  @unique @map("qr_token")
  receiptHash       String?  @map("receipt_hash") // SHA256 of contents
  status            String   @default("pending") // pending|paid|cancelled|disputed
  declarative       Boolean  @default(false) @map("declarative")
  
  digitalDeliveryId String?  @map("digital_delivery_id")
  delivery          DigitalDelivery? @relation(fields: [digitalDeliveryId], references: [id])

  createdAt         DateTime @default(now()) @map("created_at")

  @@map("receipts")
  @@index([leaseId])
  @@index([periodMonth])
}


// ═══════════════════════════════════════════════════════
// ARREARS & PROCEDURES (Part 11)
// ═══════════════════════════════════════════════════════
model LeaseArrear {
  id        String   @id @default(uuid())
  leaseId   String   @map("lease_id")
  lease     Lease    @relation(fields: [leaseId], references: [id])
  dueDate   DateTime @map("due_date") @db.Date
  amount    Int
  status    String   @default("unpaid") // unpaid|paid|partial|waived
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("lease_arrears")
  @@index([dueDate, status])
}

model ProcedurePhase {
  id          String   @id @default(uuid())
  leaseId     String   @map("lease_id")
  lease       Lease    @relation(fields: [leaseId], references: [id])
  phaseNumber Int      @map("phase_number")
  name        String
  description String?  @db.Text
  actionDate  DateTime @default(now()) @map("action_date")
  metadata    Json?
  
  @@map("procedure_phases")
}

// ═══════════════════════════════════════════════════════
// CDC DEPOSIT (Part 10)
// ═══════════════════════════════════════════════════════
model CDCDeposit {
  id              String   @id @default(uuid())
  leaseId         String   @unique @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  amount          Int
  initiator       CDCDepositInitiator @default(OWNER)
  cdcReference    String?  @map("cdc_reference")
  status          CDCDepositStatus @default(AWAITING_PAYMENT)
  proofHash       String?  @map("proof_hash")
  consignedAt     DateTime? @map("consigned_at")
  returnedAt      DateTime? @map("returned_at")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("cdc_deposits")
}

// ═══════════════════════════════════════════════════════
// MANDATES (Part 12)
// ═══════════════════════════════════════════════════════
model Mandate {
  id                String   @id @default(uuid())
  mandateRef        String   @unique @map("mandate_ref")
  propertyId        String   @map("property_id")
  property          Property @relation(fields: [propertyId], references: [id])
  agentUserId       String   @map("agent_id")
  agent             User     @relation("AgentMandates", fields: [agentUserId], references: [id])
  mandateType       String   @map("mandate_type") // management_simple|management_extended|rental|sale
  commissionPct     Decimal  @map("commission_pct") @db.Decimal(5, 2) // max 15.00
  startDate         DateTime @map("start_date") @db.Date
  endDate           DateTime? @map("end_date") @db.Date
  status            String   @default("draft") // draft|active|expired|terminated
  signedAt          DateTime? @map("signed_at")
  proofHash         String?  @map("proof_hash")
  pdfUrl            String?  @map("pdf_url")
  
  leases            Lease[]
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("mandates")
}

// ═══════════════════════════════════════════════════════
// SCORING & CERTIFICATES (Part 13 & 14)
// ═══════════════════════════════════════════════════════
model ReliabilityScore {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  score           Int // 0-100
  grade           String // A|B|C|D|E|F
  breakdown       Json // payment_timeliness, payment_completeness, etc.
  
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("reliability_scores")
}

model Certificate {
  id              String    @id @default(uuid()) @map("cert_id")
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id])
  certType        String    @map("cert_type") // CNL (Certificat Numérique Locataire)
  issuedAt        DateTime  @default(now()) @map("issued_at")
  expiresAt       DateTime  @map("expires_at")
  qrToken         String    @unique @map("qr_token")
  pdfUrl          String?   @map("pdf_url")
  status          String    @default("valid") // valid|expired|revoked
  
  @@map("certificates")
}

model Passport {
  id              String   @id @default(uuid())
  propertyId      String   @map("property_id")
  property        Property @relation(fields: [propertyId], references: [id])
  content         Json // Immutable facts about property history
  
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("passports")
}

// ═══════════════════════════════════════════════════════
// DISPUTES & MEDIATION (Part 16)
// ═══════════════════════════════════════════════════════
model Dispute {
  id              String   @id @default(uuid())
  leaseId         String   @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  title           String
  description     String   @db.Text
  amountInDispute Int?     @map("amount_in_dispute")
  status          DisputeStatus @default(OPEN)
  resolution      String?  @db.Text
  
  messages        DisputeMessage[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("disputes")
}

model DisputeMessage {
  id          String   @id @default(uuid())
  disputeId   String   @map("dispute_id")
  dispute     Dispute  @relation(fields: [disputeId], references: [id])
  senderId    String   @map("sender_id")
  content     String   @db.Text
  attachments String[]
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("dispute_messages")
}

// ═══════════════════════════════════════════════════════
// INTEGRATIONS & SYSTEM (Part 17, 19, 20, 23)
// ═══════════════════════════════════════════════════════
model DigitalDelivery {
  id             String   @id @default(uuid())
  trackingNumber String   @unique @map("tracking_number") // CI-POST-2026-00123
  deliveryMode   String   @map("delivery_mode") // maposte_number|physical_address|post_office
  status         String   @default("submitted") // submitted|in_transit|delivered|failed|returned
  recipientData  Json     @map("recipient_data")
  deliveredAt    DateTime? @map("delivered_at")
  
  receipts       Receipt[]
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("digital_deliveries")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  channel   String @default("PUSH") // SMS|PUSH|EMAIL|WHATSAPP|USSD_PUSH|COURRIER
  title     String?
  content   String   @db.Text
  type      String   @default("INFO")
  link      String?
  status    String   @default("pending") // pending|sent|delivered|failed
  read      Boolean  @default(false)
  retryCount Int     @default(0) @map("retry_count")
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model ObservatorySnapshot {
  id          String   @id @default(uuid())
  commune     String
  propertyType String  @map("property_type")
  period      String // YYYY-QX
  avgRent     Int      @map("avg_rent")
  medianRent  Int      @map("median_rent")
  minRent     Int      @map("min_rent")
  maxRent     Int      @map("max_rent")
  sampleCount Int      @map("sample_count")
  trendPct    Decimal  @map("trend_pct") @db.Decimal(5, 2)
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("observatory_snapshots")
  @@index([commune, period])
}

model MarketData {
  id              String   @id @default(uuid())
  city            String
  commune         String
  propertyType    String   @map("property_type")
  averageRent     Float    @map("average_rent")
  sampleSize      Int      @map("sample_size")
  
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([city, commune, propertyType], name: "city_commune_propertyType")
  @@map("market_data")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String // User creation, lease signed, payment processed...
  module    String // AUTH|KYC|LEASE|PAYMENT|...
  entityId  String?  @map("entity_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  proofHash String?  @map("proof_hash")
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_log")
}

model WebhookEvent {
  id             String   @id @default(uuid())
  operator       String // orange|mtn|moov|wave|maposte|cdcci
  eventType      String   @map("event_type")
  payload        Json
  signatureValid Boolean  @map("signature_valid")
  processed      Boolean  @default(false)
  
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("webhook_events")
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model Incident {
  id        String   @id @default(uuid())
  leaseId   String   @map("lease_id")
  lease     Lease    @relation(fields: [leaseId], references: [id])
  type      String // Damage, late payment, early exit, etc.
  severity  String   @default("MEDIUM") // LOW|MEDIUM|HIGH|CRITICAL
  description String @db.Text
  resolved  Boolean  @default(false)
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("incidents")
}

model Insurance {
  id              String   @id @default(uuid())
  leaseId         String   @unique @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  provider        String
  policyNo        String   @unique @map("policy_no")
  status          InsuranceStatus @default(ACTIVE)
  
  claims          InsuranceClaim[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("insurances")
}

model InsuranceClaim {
  id              String   @id @default(uuid())
  insuranceId     String   @map("insurance_id")
  insurance       Insurance @relation(fields: [insuranceId], references: [id])
  amount          Int
  reason          String
  status          InsuranceClaimStatus @default(OPEN)
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("insurance_claims")
}

model RepaymentPlan {
  id              String   @id @default(uuid())
  leaseId         String   @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  details         String   @db.Text
  status          PlanStatus @default(PROPOSED)
  tenantSignature String?  @map("tenant_signature")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("repayment_plans")
}

model Mediation {
  id              String   @id @default(uuid())
  leaseId         String   @unique @map("lease_id")
  lease           Lease    @relation(fields: [leaseId], references: [id])
  subject         String
  status          MediationStatus @default(OPEN)
  
  messages        MediationMessage[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("mediations")
}

model MediationMessage {
  id              String   @id @default(uuid())
  mediationId     String   @map("mediation_id")
  mediation       Mediation @relation(fields: [mediationId], references: [id])
  senderId        String   @map("sender_id")
  sender          User     @relation(fields: [senderId], references: [id])
  content         String   @db.Text
  
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("mediation_messages")
}

model NewsTicker {
  id        String   @id @default(uuid()) @map("news_id")
  content   String   @db.Text
  priority  Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("news_tickers")
}

// ═══════════════════════════════════════════════════════
// MODULE M17 — FISCAL REGISTRATION
// ═══════════════════════════════════════════════════════
model FiscalDossier {
  id                  String       @id @default(uuid()) @map("fiscal_id")
  leaseId             String       @map("bail_id")
  lease               Lease        @relation(fields: [leaseId], references: [id])
  
  loyerMensuel        Int          @map("loyer_mensuel")
  dureeBailMois       Int          @map("duree_bail_mois")
  dureeRetenueMois    Int          @map("duree_retenue_mois")
  baseCalcul          Int          @map("base_calcul")
  tauxApplique        Decimal      @default(0.0250) @map("taux_applique") @db.Decimal(5, 4)
  droitsEnregistrement Int          @map("droits_enregistrement")
  fraisTimbre         Int          @default(1000) @map("frais_timbre")
  fraisQapril         Int          @map("frais_qapril")
  totalDgi            Int          @map("total_dgi")
  totalBailleur       Int          @map("total_bailleur")
  penaltyAmount       Int          @default(0) @map("penalty_amount")
  exonere             Boolean      @default(false)

  statut              FiscalStatus @default(EN_ATTENTE_DECLARATION)
  dateLimiteLegale    DateTime     @map("date_limite_legale")
  
  cinetpayTransId     String?      @map("cinetpay_transaction_id")
  cinetpayPaymentUrl  String?      @map("cinetpay_payment_url")
  paidAt              DateTime?    @map("paid_at")

  certificat          CertificatFiscal?

  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@map("fiscal_dossiers")
  @@index([leaseId])
  @@index([statut])
}

model CertificatFiscal {
  id                String        @id @default(uuid()) @map("certificat_id")
  fiscalId          String        @unique @map("fiscal_id")
  fiscalDossier     FiscalDossier @relation(fields: [fiscalId], references: [id])
  
  numeroCertificat  String        @unique @map("numero_certificat")
  qrToken           String        @unique @map("qr_token")
  pdfPath           String        @map("pdf_path")
  hashSha256        String        @map("hash_sha256")
  
  issuedAt          DateTime      @default(now()) @map("issued_at")
  status            String        @default("VALIDE")

  @@map("certificats_fiscaux")
}

